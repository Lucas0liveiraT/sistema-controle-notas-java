import java.util.Scanner;

public class SistemaControleNotas {

    public static void main(String[] args) {

        Scanner scanner = new Scanner(System.in);

        System.out.println("Quantidade de alunos: ");
        int quantidadeAlunos = scanner.nextInt();
        scanner.nextLine();

        if (quantidadeAlunos <= 0) {
            System.out.println("Quantidade inválida.");
            scanner.close();
            return;
        }

        double somaNotas = 0;
        double maiorNota = 0;
        double menorNota = Double.MAX_VALUE;
        int aprovados = 0;
        String nomeMaiorNota = "";

        for (int i = 1; i <= quantidadeAlunos; i++) {

            System.out.println("\nAluno " + i);

            System.out.println("Nome: ");
            String nome = scanner.nextLine();

            System.out.println("Nota: ");
            double nota = scanner.nextDouble();
            scanner.nextLine();

            somaNotas += nota;

            if (nota > maiorNota) {
                maiorNota = nota;
                nomeMaiorNota = nome;
            }

            if (nota < menorNota) {
                menorNota = nota;
            }

            if (nota >= 6) {
                aprovados++;
            }
        }

        double media = calcularMedia(somaNotas, quantidadeAlunos);

        mostrarRelatorio(media, maiorNota, menorNota, aprovados, nomeMaiorNota);

        scanner.close();
    }

    public static double calcularMedia(double soma, int quantidade) {
        return soma / quantidade;
    }

    public static void mostrarRelatorio(double media, double maior, double menor,
                                        int aprovados, String nomeMaior) {

        System.out.println("\n===== RELATÓRIO FINAL =====");
        System.out.printf("Média da turma: %.2f%n", media);
        System.out.printf("Maior nota: %.2f (%s)%n", maior, nomeMaior);
        System.out.printf("Menor nota: %.2f%n", menor);
        System.out.printf("Aprovados: %d%n", aprovados);
    }
}
